# =============================================
# AiAgent 环境配置文件
# =============================================
# 复制此文件为 .env 并填写实际配置值
# .env 已添加到 .gitignore，不会被提交到版本控制
# =============================================

# ============================================
# 应用基础配置
# ============================================
ENVIRONMENT=development
DEBUG=true
APP_NAME=ai-agent-backend
APP_VERSION=1.0.0
LOG_LEVEL=INFO
LOG_FILE_PATH=../logs/app.log
ALLOWED_ORIGINS=http://localhost:3000
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ============================================
# 数据库配置 (PostgreSQL)
# ============================================
DATABASE_USER=postgres
DATABASE_PASSWORD=123qweasdzxc
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=aiagent
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ============================================
# Redis 配置
# ============================================
REDIS_URL=redis://localhost:6379/0
CACHE_EXPIRE_SECONDS=3600

# ============================================
# JWT 认证配置
# ============================================
# 生成密钥命令: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# LLM 大模型配置
# ============================================
# 至少需要配置一个 Provider

# ---------- DeepSeek（推荐 - 性价比最高）----------
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---------- Kimi/月之暗面（长上下文能力强）----------
KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ---------- 智谱 GLM（中文支持好）----------
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4-flash
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ---------- OpenAI ----------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ---------- Anthropic Claude（复杂推理能力强）----------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ---------- Google Gemini（免费额度大）----------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ---------- MiniMax ----------
MINIMAX_API_KEY=
MINIMAX_MODEL=abab6.5s-chat
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# ---------- Ollama（本地/离线使用）----------
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434/v1

# ============================================
# 模型路由策略
# ============================================
LLM_DEFAULT_STRATEGY=balance
# balance: 性价比最优（推荐）
# cost: 成本最低
# quality: 能力最强（最大上下文窗口）

# ============================================
# Agent 配置
# ============================================
AGENT_LLM_PROVIDER=deepseek
AGENT_LLM_MODEL=deepseek-v4-flash
AGENT_MAX_ITERATIONS=5
AGENT_TIMEOUT=120

# ============================================
# 预算管理
# ============================================
BUDGET_DAILY_LIMIT=10.0
BUDGET_MONTHLY_LIMIT=100.0
BUDGET_WARNING_THRESHOLD=80
BUDGET_DEGRADATION_THRESHOLD=95

# ============================================
# SMTP 邮件配置（可选功能）
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
EMAILS_FROM_EMAIL=your-email@gmail.com
EMAIL_NOTIFICATION_ENABLED=false
EMAIL_NOTIFICATION_RECIPIENTS=

# ============================================
# 通知配置（可选功能）
# ============================================

# ---------- 飞书 ----------
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK_URL=

# ---------- 企业微信 ----------
WECOM_CORP_ID=
WECOM_CORP_SECRET=
WECOM_AGENT_ID=

# ---------- 钉钉 ----------
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=

# ============================================
# 对象存储配置（可选功能）
# ============================================

# ---------- 腾讯云 COS ----------
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_REGION=ap-guangzhou
TENCENT_COS_BUCKET=
TENCENT_COS_PREFIX=aiagent/

# ---------- 阿里云 OSS ----------
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_REGION=oss-cn-hangzhou
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_PREFIX=aiagent/

# ---------- MinIO（S3 兼容）----------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aiagent

# 存储提供者: local | tencent_cos | aliyun_oss | minio
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=../uploads

# ============================================
# 经验库/向量数据库配置（可选功能）
# ============================================
EXPERIENCE_VECTOR_DB_TYPE=memory
EXPERIENCE_COLLECTION=aiagent_experience

# ============================================
# Docker 沙箱配置（可选功能）
# ============================================
SANDBOX_ENABLED=true
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_MEMORY_LIMIT=512
SANDBOX_TIMEOUT=300

# ============================================
# 可观测性配置（可选功能）
# ============================================
LANGFUSE_SECRET=
LANGFUSE_SALT=
